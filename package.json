{
  "name": "orion-ide",
  "version": "2.2.0",
  "description": "AI-Powered Coding Assistant for the Terminal. 60+ commands. Claude, GPT, Ollama. Cross-platform.",
  "type": "module",
  "productName": "Orion IDE",
  "author": {
    "name": "Orion Team",
    "email": "team@orion-ide.dev",
    "url": "https://orion-ide.dev"
  },
  "license": "MIT",
  "homepage": "https://github.com/concrete-sangminlee/orion#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/concrete-sangminlee/orion.git"
  },
  "bugs": {
    "url": "https://github.com/concrete-sangminlee/orion/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ide",
    "editor",
    "code-editor",
    "ai",
    "electron",
    "typescript",
    "developer-tools"
  ],
  "files": [
    "dist-cli/",
    "cli/",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist-electron/main.js",
  "bin": {
    "orion": "./dist-cli/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "electron:dev": "vite build && electron .",
    "icons": "electron-icon-builder --input=public/icon.png --output=build --flatten",
    "icons:help": "echo \"To generate icons: 1) Create a 1024x1024 PNG at public/icon.png  2) npm install -D electron-icon-builder  3) npm run icons  -- See build/ICON_README.txt for manual methods\"",
    "package": "vite build && electron-builder --config electron-builder.yml",
    "package:win": "vite build && electron-builder --config electron-builder.yml --win",
    "package:mac": "vite build && electron-builder --config electron-builder.yml --mac",
    "package:linux": "vite build && electron-builder --config electron-builder.yml --linux",
    "package:all": "vite build && electron-builder --config electron-builder.yml -mwl",
    "prepublishOnly": "npm run cli:build",
    "cli:build": "npx esbuild cli/index.ts --bundle --platform=node --target=node18 --outfile=dist-cli/index.js --banner:js=\"#!/usr/bin/env node\" --external:@anthropic-ai/sdk --external:openai --external:commander --external:chalk --external:ora --external:inquirer --external:marked --external:marked-terminal --external:cli-highlight",
    "cli:dev": "npx tsx cli/index.ts",
    "test:cli": "vitest run cli/__tests__/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@monaco-editor/react": "^4.7.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "electron-store": "^10.0.0",
    "inquirer": "^13.3.2",
    "lucide-react": "^0.577.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "monaco-editor": "^0.52.0",
    "openai": "^6.27.0",
    "ora": "^9.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "uuid": "^11.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "jsdom": "^25.0.0",
    "node-pty": "^1.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^3.0.0"
  }
}
